{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "NoteCapt 默认权限 — 最小化权限原则",
  "windows": ["main", "dropzone"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging",
    "drag:default"
  ]
}
