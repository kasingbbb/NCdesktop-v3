{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NoteCapt",
  "version": "0.1.0",
  "identifier": "com.notecapt.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "NoteCapt",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/runtime-manifest.json": "runtime-manifest.json",
      "resources/python": "python",
      "resources/markitdown-venv": "markitdown-venv",
      "resources/scripts/*.py": "scripts/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
